<div class="insta_gallery">
    <div class="container">

        <h2 class="insta_gallery_title">{{ section.settings.title }}</h2>

        <div class="insta_gallery_grid">

            {% for block in section.blocks %}
            <a href="{{ block.settings.link }}" class="insta_gallery_item" target="_blank">

                <img src="{{ block.settings.image | img_url: '400x' }}" alt="instagram">

                <div class="insta_overlay">
                    <span>View</span>
                </div>

            </a>
            {% endfor %}

        </div>

    </div>
</div>

<style>
    .insta_gallery {
        padding: 60px 0;
        text-align: center;
    }

    .insta_gallery_title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 40px;
    }

    .insta_gallery_grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 20px;
    }

    .insta_gallery_item {
        position: relative;
        overflow: hidden;
        border-radius: 10px;
    }

    .insta_gallery_item img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        transition: 0.4s;
    }

    .insta_gallery_item:hover img {
        transform: scale(1.1);
    }

    .insta_overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.3s;
    }

    .insta_gallery_item:hover .insta_overlay {
        opacity: 1;
    }

    .insta_overlay span {
        color: #fff;
        font-size: 18px;
        font-weight: 600;
    }
</style>


{% schema %}
{
"name": "Instagram Gallery",
"settings": [
{
"type": "text",
"id": "title",
"label": "Section Title",
"default": "Follow Us On Instagram"
}
],

"blocks":[
{
"type":"image",
"name":"Instagram Image",
"settings":[
{
"type":"image_picker",
"id":"image",
"label":"Image"
},
{
"type":"url",
"id":"link",
"label":"Instagram Link"
}
]
}
],

"max_blocks":6,

"presets":[
{
"name":"Instagram Gallery"
}
]
}
{% endschema %}