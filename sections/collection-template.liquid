<div class="collection_page">
    <div class="container">

        <div class="collection_header">
            <h1 class="collection-title">{{ collection.title }}</h1>
            <p class="collection-description">{{ collection.description }}</p>
        </div>

        <div class="product-grid">
            {% for product in collection.products %}
            <div class="product-card">

                <a href="{{ product.url }}" class="product-image">
                    <img src="{{ product.featured_image | img_url: '500x' }}" alt="{{ product.title }}">
                </a>

                <div class="product-info">
                    <h3 class="product-title">
                        <a href="{{ product.url }}">{{ product.title }}</a>
                    </h3>

                    <p class="product-price">
                        {{ product.price | money }}
                    </p>

                    <a href="{{ product.url }}" class="view-btn">
                        View Product
                    </a>
                </div>

            </div>
            {% endfor %}
        </div>

    </div>
</div>


<style>
    .collection_page {
        padding: 60px 0;
        background: #f9f9f9;
    }

    .collection_header {
        text-align: center;
        margin-bottom: 50px;
    }

    .collection-title {
        font-size: 38px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .collection-description {
        font-size: 16px;
        color: #666;
        max-width: 600px;
        margin: auto;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
    }

    .product-card {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: 0.3s;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .product-image img {
        width: 100%;
        height: 280px;
        object-fit: cover;
    }

    .product-info {
        padding: 20px;
        text-align: center;
    }

    .product-title {
        font-size: 18px;
        margin-bottom: 10px;
    }

    .product-title a {
        text-decoration: none;
        color: #111;
    }

    .product-price {
        font-size: 18px;
        font-weight: 600;
        color: #e63946;
        margin-bottom: 15px;
    }

    .view-btn {
        display: inline-block;
        padding: 10px 20px;
        background: #111;
        color: #fff;
        text-decoration: none;
        border-radius: 5px;
        font-size: 14px;
        transition: 0.3s;
    }

    .view-btn:hover {
        background: #e63946;
    }

    @media (max-width:768px) {

        .collection-title {
            font-size: 28px;
        }

        .product-image img {
            height: 220px;
        }

    }
</style>

{% comment %} {% 'releted-products' %} {% endcomment %}

{% schema %}
{
"name": "collection",
"settings": [],
"presets": [
{"name": "collection",
"settings": {}}
]
}
{% endschema %}