<div class="new-arrivals">
    <div class="container">
        <h2 class="section-title">{{ section.settings.heading }}</h2>

        <div class="products-grid">

            {% if section.settings.collection != blank %}

            {% for product in section.settings.collection.products limit: section.settings.products_to_show %}

            <div class="product-card">
                <a href="{{ product.url }}">
                    <img src="{{ product.featured_image | image_url: width: 500 }}" alt="{{ product.title }}">

                    <h3>{{ product.title }}</h3>

                    <p class="price">
                        {{ product.price | money }}
                    </p>
                </a>
            </div>

            {% endfor %}

            {% else %}

            <p style="text-align:center;">Please select a collection</p>

            {% endif %}

        </div>
    </div>
</div>


<style>
    .new-arrivals {
        padding: 60px 0;
    }

    .section-title {
        text-align: center;
        font-size: 32px;
        margin-bottom: 40px;
        font-weight: 600;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
    }

    .product-card {
        text-align: center;
        transition: 0.3s;
    }

    .product-card img {
        width: 100%;
        border-radius: 10px;
    }

    .product-card h3 {
        font-size: 18px;
        margin-top: 10px;
        color: #111;
    }

    .product-card .price {
        color: #777;
        font-size: 16px;
    }

    .product-card:hover {
        transform: translateY(-5px);
    }

    @media(max-width:992px) {

        .products-grid {
            grid-template-columns: repeat(2, 1fr);
        }

    }

    @media(max-width:576px) {

        .products-grid {
            grid-template-columns: 1fr;
        }

    }
</style>


{% schema %}
{
"name": "New Arrivals",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Section Heading",
"default": "New Arrivals"
},
{
"type": "collection",
"id": "collection",
"label": "Select Collection"
},
{
"type": "range",
"id": "products_to_show",
"label": "Products to show",
"min": 3,
"max": 12,
"step": 1,
"default": 8
}
],
"presets": [
{
"name": "New Arrivals"
}
]
}
{% endschema %}